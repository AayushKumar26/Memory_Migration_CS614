+		MIG_TIMING_BUFSIZE);
+	pr_info("mig_timing: interface at /sys/kernel/debug/mig_timing\n");
+
+	/* Benchmark 3: downtime interface — dt_timing_fops declared above */
+	debugfs_create_file("mig_downtime", 0666, NULL, NULL, &dt_timing_fops);
+	pr_info("mig_downtime: interface at /sys/kernel/debug/mig_downtime\n");
