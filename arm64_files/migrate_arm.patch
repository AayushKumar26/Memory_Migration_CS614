+/* ===================================================================
+ * ROCM — Read-Only Copy-then-swap Migration
+ *
+ * For pages whose every PTE is read-only, the standard migration PTE
+ * (Present=0) installed during Stage 2 is architecturally unnecessary:
+ * no writer can exist, so src content is immutable throughout the copy.
+ *
+ * Standard pipeline:
+ *   Lock → [Unmap → Copy → Remap] → Unlock
+ *           ↑ application stall window ↑
+ *
+ * ROCM pipeline (read-only pages only):
+ *   Lock → Copy → [atomic PTE swap] → Unlock
+ *                  ↑ tiny window ↑
+ *
+ * Projected downtime reduction (from baseline data):
+ *   4KB  pages: 1.10µs → 0.07µs  (~15×)
+ *   2MB  THP:  72.32µs → 0.73µs  (~99×)
+ *
+ * ARM64 specifics:
+ *   - folio_copy() uses NEON __pi_memcpy() at full bandwidth
+ *   - PTE swap issues TLBI VAE1IS (hardware broadcast, no IPI needed)
+ *   - Single DSB ISH after rmap walk amortises barrier cost
+ *   - BBM (Break-Before-Make) compliance:
+ *       ptep_get_and_clear → TLBI VAE1IS → DSB ISH → set_pte_at
+ * =================================================================== */
+
+/*
+ * folio_all_mappings_readonly - test whether ROCM fast path is safe.
+ *
+ * Two-level check:
+ *
+ *   Fast path  — mapping_can_writeback() returns false (AS_NO_WRITEBACK set).
+ *                Covers shared library .text/.rodata and read-only block files.
+ *                O(1), no page table walk needed.
+ *
+ *   Slow path  — folio_rmap_all_readonly(): walk every PTE and call
+ *                pte_write().  Handles the common case of a file opened
+ *                O_RDONLY on a writable filesystem (tmpfs, ext4, etc.)
+ *                that is mmap'd PROT_READ.  The filesystem has a writepage
+ *                method so mapping_can_writeback() returns true, but every
+ *                installed PTE lacks the write bit.  This is exactly what
+ *                the benchmark's tmpfile test produces.
+ *
+ * All mandatory fallback conditions are checked first (dirty, swapcache,
+ * KSM, anonymous, no mapping, ASYNC mode).
+ */
+
+/*
+ * rocm_ro_check_ctx — state for the PTE read-only rmap walk below.
+ */
+struct rocm_ro_check_ctx {
+	bool found_writable;
+};
+
+/*
+ * rocm_check_one_pte_readonly - rmap_walk callback for the slow path.
+ *
+ * Walks all PTEs for one VMA mapping of the folio.  Returns false
+ * (aborting the entire rmap walk) as soon as any writable PTE is found.
+ * PTL is acquired per-PTE by page_vma_mapped_walk() as usual.
+ */
+static bool rocm_check_one_pte_readonly(struct folio *folio,
+					 struct vm_area_struct *vma,
+					 unsigned long addr, void *arg)
+{
+	struct rocm_ro_check_ctx *ctx = arg;
+	DEFINE_FOLIO_VMA_WALK(pvmw, folio, vma, addr, PVMW_SYNC);
+
+	while (page_vma_mapped_walk(&pvmw)) {
+		if (pvmw.pte && pte_write(ptep_get(pvmw.pte))) {
+			ctx->found_writable = true;
+			page_vma_mapped_walk_done(&pvmw);
+			return false;	/* abort walk — no need to check further */
+		}
+	}
+	return true;
+}
+
+/*
+ * folio_rmap_all_readonly - return true iff every PTE mapping folio
+ * currently lacks the write bit.
+ *
+ * Cost: O(mapcount) page table locks + pte_write() checks.
+ * For the common single-mapping case this is one PTL acquire/release.
+ * For shared library pages mapped by N processes it is O(N), but those
+ * are already caught by the fast path (mapping_can_writeback = false).
+ */
+static bool folio_rmap_all_readonly(struct folio *folio)
+{
+	struct rocm_ro_check_ctx ctx = { .found_writable = false };
+	struct rmap_walk_control rwc = {
+		.rmap_one = rocm_check_one_pte_readonly,
+		.arg      = &ctx,
+	};
+
+	rmap_walk(folio, &rwc);
+	return !ctx.found_writable;
+}
+
+static bool folio_all_mappings_readonly(struct folio *folio,
+					enum migrate_mode mode)
+{
+	/*
+	 * Only allow ROCM on explicit MIGRATE_SYNC (move_pages() syscall).
+	 *
+	 * MIGRATE_ASYNC      — kcompactd async pass, different locking model.
+	 * MIGRATE_SYNC_LIGHT — kcompactd sync pass; cannot block on writeback.
+	 *                      Both compaction modes must use the standard path
+	 *                      to avoid corrupting compaction's page state.
+	 * MIGRATE_SYNC_NO_COPY — no folio_copy() call, ROCM copy step invalid.
+	 */
+	if (mode != MIGRATE_SYNC)
+		return false;
+
+	/* Dirty: writeback in flight could modify src during copy */
+	if (folio_test_dirty(folio))
+		return false;
+
+	/* Swap cache: swap machinery writes behind rmap */
+	if (folio_test_swapcache(folio))
+		return false;
+
+	/* KSM: content-equality invariant must hold under KSM locks */
+	if (folio_test_ksm(folio))
+		return false;
+
+	/* Anonymous: CoW potential means a writable mapping may exist
+	 * even for PROT_READ — skip to avoid false positives. */
+	if (folio_test_anon(folio))
+		return false;
+
+	/* No mapping: can't verify read-only status */
+	if (!folio->mapping)
+		return false;
+
+	/*
+	 * Fast path: non-writable file-backed mapping (O(1)).
+	 * mapping_can_writeback() returns false when AS_NO_WRITEBACK is set,
+	 * meaning the mapping has no writepage method at all.
+	 * Covers: shared library .text/.rodata, O_RDONLY block files.
+	 */
+	if (!mapping_can_writeback(folio->mapping))
+		return true;
+
+	/*
+	 * Slow path: writeback-capable filesystem (tmpfs, ext4, …) but
+	 * the file may be mmap'd PROT_READ only.  Walk every PTE and
+	 * check pte_write().  If none has the write bit set, the content
+	 * is guaranteed immutable for the duration of the copy — ROCM safe.
+	 *
+	 * This is the case the benchmark exercises: a tmpfile opened
+	 * O_RDONLY and mmap'd MAP_SHARED|PROT_READ.  tmpfs has writepage
+	 * (it backs to swap), so the fast path misses it, but every
+	 * installed PTE lacks the write bit.
+	 */
+	return folio_rmap_all_readonly(folio);
+}
+
+/*
+ * Context passed through the rmap walk in rocm_swap_ptes().
+ * dst is the destination folio whose PTE will be installed
+ * in place of each src PTE.
+ */
+struct rocm_swap_ctx {
+	struct folio *dst;
+	int		n_swapped;	/* count of PTEs successfully swapped */
+	int		n_to_put;	/* folio_put(src) calls deferred to after walk */
+};
+
+/*
+ * rocm_swap_one_pte - rmap_walk callback: atomically swap one PTE.
+ *
+ * Called once per VMA that maps src_folio.  Performs the ARM64
+ * Break-Before-Make sequence for each PTE mapping:
+ *
+ *   1. ptep_get_and_clear()   — atomically clear src PTE
+ *   2. flush_tlb_page()       — TLBI VAE1IS (hardware-broadcast)
+ *   3. page_remove_rmap()     — decrement src mapcount + zone stats
+ *   4. folio_get(dst)         — acquire PTE reference on dst
+ *   5. page_add_file_rmap()   — increment dst mapcount + zone stats
+ *   6. set_pte_at()           — install dst PTE (BBM complete)
+ *   7. update_mmu_cache()     — notify arch of new translation
+ *
+ * NOTE: folio_put(src) is intentionally deferred — it is NOT called
+ * here.  Dropping a src reference inside the rmap walk is unsafe:
+ * if src's refcount hits zero mid-walk, page allocator state is
+ * corrupted (the kcompactd BUG: Bad page state).  Instead we
+ * increment ctx->n_to_put and rocm_swap_ptes() calls folio_put(src)
+ * n_to_put times after the walk completes and the DSB ISH is issued.
+ *
+ * The PTL (page table lock) is held throughout by page_vma_mapped_walk().
+ * DSB ISH is deferred to rocm_swap_ptes() after the full rmap walk,
+ * amortising the barrier cost across all mappings.
+ *
+ * PMD-mapped THP entries are not yet supported: if encountered the walk
+ * is aborted and the caller falls back to the standard pipeline.
+ *
+ * Returns true to continue the walk, false to abort (PMD case).
+ */
+static bool rocm_swap_one_pte(struct folio *src, struct vm_area_struct *vma,
