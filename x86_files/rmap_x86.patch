+	u64 rwsem_ns;
+	u64 ptl_ns;
+	u64 ipi_ns;
+};
+DEFINE_PER_CPU(struct mig_rmap_timing, mig_rmap_timing);
+EXPORT_SYMBOL_GPL(mig_rmap_timing);
+#endif /* CONFIG_MIG_RMAP_TIMING */
