+static const struct file_operations mig_timing_fops = {
+	.owner	 = THIS_MODULE,
+	.open	 = mig_timing_open,
+	.read	 = seq_read,
+	.write	 = mig_timing_write,
+	.llseek	 = seq_lseek,
+	.release = single_release,
+};
